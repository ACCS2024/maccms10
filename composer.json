{
    "name": "maccms/maccms10",
    "description": "苹果CMS v10 — ThinkPHP 8.x",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.0",
        "ext-json": "*",
        "ext-pdo": "*",
        "topthink/framework": "^8.1",
        "topthink/think-multi-app": "^1.0",
        "topthink/think-view": "^2.0",
        "topthink/think-captcha": "^3.0",
        "topthink/think-helper": "^3.0",
        "topthink/think-image": "^1.0",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "app\\": "application/",
            "addons\\": "addons/",
            "think\\": "application/common/addons/",
            "Qiniu\\": "extend/qiniu/src/Qiniu/",
            "Upyun\\": "extend/upyun/src/Upyun/"
        },
        "files": [
            "application/common/addons/common.php"
        ],
        "classmap": [
            "application/common/util/Qrcode.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
