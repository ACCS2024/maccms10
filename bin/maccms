#!/usr/bin/env bash
# =============================================================================
# maccms-cli —— WP-CLI 式一键建站工具
#   new        在指定路径部署并安装一个全新站点
#   install    在当前代码树就地安装
#   reinstall  删锁+覆盖重装(开发回到干净态)
#   destroy    销毁站点(删库/账号 + 删目录)
#   doctor     环境体检
#   help       使用帮助
# 口令安全:MySQL root 口令经 环境变量 MACCMS_DB_ROOT_PASS / stdin / 交互输入,
#           绝不通过命令行参数传递。
# =============================================================================
set -euo pipefail

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SRC_ROOT="$(cd "$SELF_DIR/.." && pwd)"   # 源码树根(本仓库)
# shellcheck source=/dev/null
source "$SELF_DIR/_common.sh"

# 配置文件发现:$MACCMS_CLI_CONFIG > ./maccms-cli.yml > <源码树>/maccms-cli.yml
CONFIG="${MACCMS_CLI_CONFIG:-}"
if [ -z "$CONFIG" ]; then
  for c in "$PWD/maccms-cli.yml" "$SRC_ROOT/maccms-cli.yml"; do
    [ -f "$c" ] && { CONFIG="$c"; break; }
  done
fi
# 安装类命令的默认参数(来自 maccms-cli.yml 的 defaults 段;命令行显式参数覆盖之)
DEFAULTS=()
if [ -n "$CONFIG" ] && [ -f "$CONFIG" ]; then
  while IFS= read -r _l; do [ -n "$_l" ] && DEFAULTS+=("$_l"); done \
    < <("$(php_bin)" "$SELF_DIR/_config.php" "$CONFIG" defaults 2>/dev/null || true)
fi

usage() {
  cat >&2 <<'EOF'
maccms-cli —— 一键建站 / 快速部署

用法:
  bin/maccms <命令> [参数]

命令:
  new <路径> --db-name=NAME --site-name=NAME [选项]
        部署代码到 <路径> 并安装一个全新站点。
        例:  echo "$ROOTPW" | bin/maccms new /var/www/site1 \
                  --db-name=site1 --site-name="我的站点"

  install --db-name=NAME --site-name=NAME [选项]
        在当前代码树就地安装(目录本身已是 maccms)。

  reinstall --db-name=NAME [选项]
        删除安装锁并覆盖重装(--cover --force),开发期秒级回到干净态。

  destroy <路径> [--drop-db --db-name=NAME --drop-user=USER]
        删除站点目录;加 --drop-db 时同时删库/账号(需 --db-name)。

  doctor
        体检 PHP 版本 / 扩展 / rsync。

  help
        显示本帮助。

  —— 以下为站点运维命令(透传给 php think;默认作用于当前代码树,
     可用 --path=<站点根> 指定其它站点) ——

  info [--format=table|json]
        站点/环境自检(版本/扩展/安装状态/数据库/可写目录/性能建议)。

  cache:flush [--with-log]
        清空 runtime 缓存(改完代码即清)。

  admin:reset-password --user=admin [--password=xxx]
        重置后台管理员口令(后台进不去时自救)。

  db:export [--file=xx.sql] [--tables=a,b]
        导出数据库到 .sql(无需 mysqldump)。

  db:import --file=xx.sql [--src-prefix=mac_ --dst-prefix=site1_]
        从 .sql 恢复数据库。

  db:search-replace OLD NEW [--dry-run] [--tables=a,b]
        跨表文本字段搜索替换(换域名/改路径);先 --dry-run 演练再执行。

多站编排(maccms-cli.yml,见 maccms-cli.yml.example):
  - defaults 段:为 new/install/reinstall 提供默认参数(免重复敲 db-host/root-user 等)。
  - aliases/groups:运维命令首参用 @别名/@分组 对多个站点批量执行,例:
        bin/maccms info @all
        bin/maccms cache:flush @site1
  - 或对任意站点用 --path=<站点根>。

脚本化:
  - 多数命令支持 --porcelain(site:install 输出 JSON;admin:reset-password 仅输出口令;
    db:export 仅输出文件路径);info 支持 --format=json。
  - reinstall 默认会"重装前自动备份",加 --no-backup 跳过。

口令传递(三选一,按优先级):
  1) 环境变量:  MACCMS_DB_ROOT_PASS=secret bin/maccms install ...
  2) 标准输入:  echo "$ROOTPW" | bin/maccms install ...
  3) 交互输入:  bin/maccms install ...        (终端会提示输入,隐藏回显)

常用选项(透传给 php think site:install,详见 `php think site:install --help`):
  --db-host=127.0.0.1   --db-port=3306   --db-prefix=mac_   --db-charset=utf8mb4
  --root-user=root      --app-user=NAME  --app-pass=PASS    --no-app-user(仅开发)
  --admin-user=admin    --admin-pass=PASS(默认随机)
  --with-initdata=1     --install-dir=/  --lang=zh-cn
  --cover(库已存在则复用)   --fresh(删库重建/干净重装)   --force(忽略 install.lock)

退出码:0 成功 / 2 参数错 / 3 写入权限 / 4 连接失败 / 5 建库失败 / 6 SQL失败 / 7 已安装
EOF
}

cmd="${1:-help}"; shift || true

case "$cmd" in
  new)
    dest="${1:-}"; [ -n "$dest" ] || die "用法: bin/maccms new <路径> --db-name=.. --site-name=.."
    shift
    log "部署代码 → $dest"
    provision_code "$SRC_ROOT" "$dest"
    ensure_writable "$dest"
    log "开始安装…"
    rp="$(read_root_pass)"
    MACCMS_DB_ROOT_PASS="$rp" "$(php_bin)" "$dest/think" site:install ${DEFAULTS[@]+"${DEFAULTS[@]}"} "$@" </dev/null
    log "完成。访问 <站点地址>/admin.php 登录后台。"
    ;;

  install)
    ensure_writable "$SRC_ROOT"
    rp="$(read_root_pass)"
    MACCMS_DB_ROOT_PASS="$rp" "$(php_bin)" "$SRC_ROOT/think" site:install ${DEFAULTS[@]+"${DEFAULTS[@]}"} "$@" </dev/null
    ;;

  reinstall)
    # 重装前自动备份(除非 --no-backup):删库重装是破坏性操作,先导出当前库兜底
    nobackup=0; passargs=()
    for a in "$@"; do case "$a" in --no-backup) nobackup=1 ;; *) passargs+=("$a") ;; esac; done
    if [ "$nobackup" = 0 ] && [ -f "$SRC_ROOT/application/data/install/install.lock" ]; then
      bk="$SRC_ROOT/runtime/backup/pre-reinstall-$(date +%Y%m%d-%H%M%S).sql"
      log "重装前自动备份 → $bk(加 --no-backup 跳过)"
      "$(php_bin)" "$SRC_ROOT/think" db:export --file="$bk" </dev/null || warn "备份失败(仍继续重装)"
    fi
    rm -f "$SRC_ROOT/application/data/install/install.lock"
    rp="$(read_root_pass)"
    MACCMS_DB_ROOT_PASS="$rp" "$(php_bin)" "$SRC_ROOT/think" site:install --fresh --force ${DEFAULTS[@]+"${DEFAULTS[@]}"} ${passargs[@]+"${passargs[@]}"} </dev/null
    ;;

  destroy)
    dest="${1:-}"; [ -n "$dest" ] || die "用法: bin/maccms destroy <路径> [--drop-db --db-name=NAME]"
    shift
    drop_db=0; passthru=()
    for a in "$@"; do
      case "$a" in
        --drop-db) drop_db=1 ;;
        *) passthru+=("$a") ;;
      esac
    done
    if [ "${MACCMS_YES:-0}" != "1" ]; then
      confirm "确认销毁站点目录 [$dest] ?" || die "已取消"
    fi
    if [ "$drop_db" = "1" ]; then
      [ -f "$dest/think" ] || die "目标无 think 入口,无法删库;请手动指定"
      rp="$(read_root_pass)"
      MACCMS_DB_ROOT_PASS="$rp" "$(php_bin)" "$dest/think" site:destroy --yes "${passthru[@]}" </dev/null || warn "删库步骤有告警"
    fi
    rm -rf "$dest"
    log "已删除目录: $dest"
    ;;

  doctor)
    check_env
    ;;

  help|-h|--help|"")
    usage
    ;;

  *)
    # 若首参为 @别名/@分组(如 @site1 / @all),解析为站点路径并对每个站执行
    if [ "${1:-}" != "${1#@}" ] && [ -n "${1:-}" ]; then
      alias_name="$1"; shift
      [ -n "$CONFIG" ] || die "未找到 maccms-cli.yml,无法解析 $alias_name(参考 maccms-cli.yml.example)"
      sites=()
      while IFS= read -r _s; do [ -n "$_s" ] && sites+=("$_s"); done \
        < <("$(php_bin)" "$SELF_DIR/_config.php" "$CONFIG" resolve "$alias_name") \
        || die "解析别名失败: $alias_name"
      [ "${#sites[@]}" -gt 0 ] || die "别名无匹配站点: $alias_name"
      rc=0
      for s in "${sites[@]}"; do
        [ -f "$s/think" ] || { warn "跳过(无 think 入口): $s"; continue; }
        log "[$alias_name → $s] $cmd ${*:-}"
        "$(php_bin)" "$s/think" "$cmd" "$@" </dev/null || rc=$?
      done
      exit $rc
    fi
    # 否则:单站透传(支持 --path=<站点根> 定位站点)
    root="$SRC_ROOT"; args=()
    for a in "$@"; do
      case "$a" in
        --path=*) root="${a#--path=}" ;;
        *) args+=("$a") ;;
      esac
    done
    [ -f "$root/think" ] || die "未找到 $root/think(用 --path=<站点根> 指定站点)"
    exec "$(php_bin)" "$root/think" "$cmd" ${args[@]+"${args[@]}"}
    ;;
esac
